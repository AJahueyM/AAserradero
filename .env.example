# ---------------------------------------------------------------------------
# Antiguo Aserradero Reserva — example environment configuration
# Copy to `.env` (git-ignored) for local development. NEVER commit real secrets.
# In Azure, these are supplied as Container App environment variables and the
# app authenticates to Azure services with a Managed Identity (no secrets).
# ---------------------------------------------------------------------------

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:8080

# --- Database ---------------------------------------------------------------
# Local dev uses SQL auth against the docker SQL Server container.
# In Azure, omit user/password and use: Authentication=Active Directory Default
ConnectionStrings__Default=Server=localhost,1433;Database=AntiguoAserradero;User Id=sa;Password=Your_strong_Pass123;Encrypt=True;TrustServerCertificate=True

# --- Microsoft Entra External ID (authentication) ---------------------------
AzureAd__Instance=https://<your-tenant>.ciamlogin.com/
AzureAd__TenantId=00000000-0000-0000-0000-000000000000
AzureAd__ClientId=00000000-0000-0000-0000-000000000000
AzureAd__Audience=api://antiguoaserradero-api

# --- Microsoft Graph (user provisioning; Managed Identity in Azure) ---------
Graph__TenantId=00000000-0000-0000-0000-000000000000
Graph__ApiClientAppId=00000000-0000-0000-0000-000000000000

# --- Azure Communication Services (email) -----------------------------------
# In Azure, authenticated via Managed Identity; endpoint only is required.
Acs__Endpoint=https://<your-acs-resource>.communication.azure.com/
Acs__SenderAddress=DoNotReply@<your-verified-domain>

# --- CORS / app URLs --------------------------------------------------------
App__FrontendBaseUrl=http://localhost:5173
App__AllowedOrigins=http://localhost:5173

# --- Observability ----------------------------------------------------------
ApplicationInsights__ConnectionString=
