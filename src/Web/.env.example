# Microsoft Entra External ID / MSAL redirect auth
VITE_AAD_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_AAD_AUTHORITY=https://your-tenant.ciamlogin.com/your-tenant.onmicrosoft.com
VITE_AAD_REDIRECT_URI=http://localhost:5173

# API access token scope and API base URL. Empty base URL uses the Vite /api proxy.
VITE_API_SCOPE=api://00000000-0000-0000-0000-000000000000/access_as_user
VITE_API_BASE_URL=
